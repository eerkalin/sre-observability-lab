{
  "uid": "application-service-overview",
  "title": "Application Service Overview",
  "tags": ["sre-lab", "application-service", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Application service UP",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"application-service\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP request rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"application-service\"}[1m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP 5xx error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"application-service\", outcome=\"SERVER_ERROR\"}[1m]))",
          "legendFormat": "5xx errors/sec",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Applications created in last 5 minutes",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "increase(business_applications_created_total{job=\"application-service\"}[5m])",
          "legendFormat": "created",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    }
  ]
}