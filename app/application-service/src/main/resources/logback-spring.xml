<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>
    <springProperty scope="context" name="environment" source="app.environment"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                time=%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%level service=${appName} env=${environment} thread=%thread logger=%logger{36} requestId=%X{requestId:-none} message="%msg"%n
            </pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
